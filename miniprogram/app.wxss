page {
  background-color: #fafaf9;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  padding-bottom: 60rpx;
}
.container {
  padding: 24rpx;
  max-width: 750rpx;
  margin: 0 auto;
}
.card {
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #f5f5f4;
  overflow: hidden;
}
.btn-primary {
  background: #059669;
  color: #fff;
  border-radius: 24rpx;
  font-weight: bold;
}
.btn-primary:active {
  opacity: 0.9;
}
.text-emerald { color: #059669; }
.text-muted { color: #a8a29e; }
