.reader-card { margin-bottom: 32rpx; min-height: 600rpx; }
.reader-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f4;
  background: #fafaf9;
}
.page-nav { display: flex; align-items: center; gap: 24rpx; }
.nav-btn { font-size: 32rpx; color: #57534e; padding: 8rpx; }
.nav-btn.disabled { opacity: 0.35; }
.page-num { font-size: 24rpx; font-weight: 600; color: #78716c; min-width: 80rpx; text-align: center; }
.reader-body { padding: 48rpx 40rpx; }
.story-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #059669;
  margin-bottom: 40rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}
.page-text {
  font-size: 36rpx;
  line-height: 1.8;
  color: #292524;
  text-align: center;
  margin-bottom: 24rpx;
}
.word { margin-right: 8rpx; }
.word:active { color: #059669; text-decoration: underline; }
.translation {
  font-size: 26rpx;
  color: #78716c;
  text-align: center;
  font-style: italic;
  margin-bottom: 32rpx;
}
.grammar-box {
  background: #ecfdf5;
  border: 1rpx solid #a7f3d0;
  border-radius: 24rpx;
  padding: 32rpx;
}
.grammar-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #059669;
  margin-bottom: 16rpx;
  text-transform: uppercase;
}
.grammar-box text { font-size: 28rpx; color: #44403c; }
.dots {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 48rpx;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e7e5e4;
}
.dot.active { width: 32rpx; border-radius: 8rpx; background: #059669; }

.book-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
}
.book-item {
  padding: 40rpx;
  text-align: center;
}
.book-item .book-icon {
  width: 96rpx;
  height: 96rpx;
  background: #d1fae5;
  border-radius: 24rpx;
  margin: 0 auto 24rpx;
}
.book-item .book-title {
  display: block;
  font-weight: 600;
  color: #292524;
  margin-bottom: 8rpx;
  font-size: 28rpx;
}
.empty { text-align: center; padding: 120rpx 0; }

.loading-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.loading-box {
  background: #fff;
  padding: 32rpx 48rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
}
.word-modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 200;
}
.word-content {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
}
.word-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32rpx; }
.word-big { display: block; font-size: 44rpx; font-weight: 700; color: #059669; }
.word-trans { font-size: 32rpx; color: #57534e; }
.word-actions { display: flex; align-items: center; gap: 24rpx; }
.example-box { background: #fafaf9; padding: 24rpx; border-radius: 16rpx; }
.example-label { font-size: 22rpx; color: #a8a29e; display: block; margin-bottom: 8rpx; }
.example-text { font-size: 28rpx; color: #44403c; font-style: italic; }
