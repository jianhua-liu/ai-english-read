.profile-card {
  padding: 64rpx 48rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.avatar {
  width: 160rpx;
  height: 160rpx;
  background: #d1fae5;
  border-radius: 50%;
  margin: 0 auto 32rpx;
}
.profile-name { display: block; font-size: 40rpx; font-weight: 700; color: #1c1917; margin-bottom: 8rpx; }
.stats { display: grid; grid-template-columns: 1fr 1fr; gap: 32rpx; }
.stat-item { padding: 40rpx; text-align: center; }
.stat-num { display: block; font-size: 48rpx; font-weight: 700; color: #059669; margin-bottom: 8rpx; }
.stat-label { font-size: 24rpx; color: #a8a29e; text-transform: uppercase; font-weight: 600; }
