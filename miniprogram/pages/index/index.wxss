.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1917;
}
.grade-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}
.grade-btn {
  flex: 1;
  min-width: 180rpx;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #57534e;
  border: 2rpx solid #e7e5e4;
}
.grade-btn.active {
  background: #059669;
  color: #fff;
  border-color: #059669;
}
.book-icon {
  width: 80rpx;
  height: 80rpx;
  background: #d1fae5;
  border-radius: 16rpx;
}
.book-title {
  display: block;
  font-weight: 600;
  color: #292524;
  margin-bottom: 8rpx;
}
.recent-item:active {
  opacity: 0.9;
}
