<view class="container">
  <view class="vocab-header">
    <text class="section-title">生词本</text>
    <text class="badge">{{vocab.length}} 词</text>
  </view>
  <block wx:for="{{vocab}}" wx:key="id">
    <view class="card vocab-item">
      <view class="vocab-main">
        <text class="vocab-word">{{item.word}}</text>
        <text class="vocab-trans">{{item.translation}}</text>
        <text class="vocab-example">"{{item.example}}"</text>
      </view>
      <view class="vocab-del" data-id="{{item.id}}" bindtap="onRemove">删除</view>
    </view>
  </block>
  <view wx:if="{{vocab.length === 0}}" class="empty">
    <text class="text-muted">生词本为空</text>
    <text class="text-muted" style="font-size: 24rpx; margin-top: 16rpx;">阅读时点击单词可加入这里</text>
  </view>
</view>
